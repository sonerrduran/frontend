{
  "name": "egitim-galaksisi-monorepo",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:teacher": "npm run dev --workspace=apps/teacher",
    "dev:admin": "npm run dev --workspace=apps/admin",
    "build": "npm run build:packages && npm run build:apps",
    "build:packages": "npm run build --workspace=packages/ui && npm run build --workspace=packages/game-engine && npm run build --workspace=packages/shared && npm run build --workspace=packages/mock-data",
    "build:apps": "npm run build --workspace=apps/web && npm run build --workspace=apps/teacher && npm run build --workspace=apps/admin",
    "build:web": "npm run build --workspace=apps/web",
    "build:teacher": "npm run build --workspace=apps/teacher",
    "build:admin": "npm run build --workspace=apps/admin",
    "preview": "npm run preview --workspace=apps/web",
    "preview:web": "npm run preview --workspace=apps/web",
    "preview:teacher": "npm run preview --workspace=apps/teacher",
    "preview:admin": "npm run preview --workspace=apps/admin",
    "test": "npm run test:unit && npm run test:property",
    "test:unit": "vitest run --coverage",
    "test:property": "vitest run --config vitest.property.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:watch": "vitest watch",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "chess.js": "^1.4.0",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.3",
    "react-chessboard": "^5.10.0",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.13.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "fast-check": "^3.15.0",
    "playwright": "^1.40.0",
    "prettier": "^3.1.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^1.0.0"
  }
}
