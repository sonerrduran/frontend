# Environment Configuration Example
# Copy this file to .env and update with your values

# Node Environment
NODE_ENV=development

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_dev_password

# Auth Service Database
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_service
AUTH_DB_PASSWORD=auth_service_password
AUTH_DB_URL=postgresql://auth_service:auth_service_password@localhost:5432/auth_db

# User Service Database
USER_DB_NAME=user_db
USER_DB_USER=user_service
USER_DB_PASSWORD=user_service_password
USER_DB_URL=postgresql://user_service:user_service_password@localhost:5432/user_db

# Game Service Database
GAME_DB_NAME=game_db
GAME_DB_USER=game_service
GAME_DB_PASSWORD=game_service_password
GAME_DB_URL=postgresql://game_service:game_service_password@localhost:5432/game_db

# Notification Service Database
NOTIFICATION_DB_NAME=notification_db
NOTIFICATION_DB_USER=notification_service
NOTIFICATION_DB_PASSWORD=notification_service_password
NOTIFICATION_DB_URL=postgresql://notification_service:notification_service_password@localhost:5432/notification_db

# MongoDB Configuration
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=mongo
MONGO_PASSWORD=mongo_dev_password
MONGO_URL=mongodb://mongo:mongo_dev_password@localhost:27017

# Content Service MongoDB
CONTENT_DB_NAME=content_db
CONTENT_DB_URL=mongodb://mongo:mongo_dev_password@localhost:27017/content_db

# Analytics Service MongoDB
ANALYTICS_DB_NAME=analytics_db
ANALYTICS_DB_URL=mongodb://mongo:mongo_dev_password@localhost:27017/analytics_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_dev_password
REDIS_URL=redis://:redis_dev_password@localhost:6379

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=rabbitmq
RABBITMQ_PASSWORD=rabbitmq_dev_password
RABBITMQ_URL=amqp://rabbitmq:rabbitmq_dev_password@localhost:5672

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# API Gateway
API_GATEWAY_PORT=3000
API_GATEWAY_HOST=localhost

# Auth Service
AUTH_SERVICE_PORT=3001
AUTH_SERVICE_HOST=localhost

# User Service
USER_SERVICE_PORT=3002
USER_SERVICE_HOST=localhost

# Game Service
GAME_SERVICE_PORT=3003
GAME_SERVICE_HOST=localhost

# AI Service
AI_SERVICE_PORT=8000
AI_SERVICE_HOST=localhost

# Content Service
CONTENT_SERVICE_PORT=3004
CONTENT_SERVICE_HOST=localhost

# Analytics Service
ANALYTICS_SERVICE_PORT=3005
ANALYTICS_SERVICE_HOST=localhost

# Notification Service
NOTIFICATION_SERVICE_PORT=3006
NOTIFICATION_SERVICE_HOST=localhost

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Email Configuration (SendGrid/SES)
EMAIL_SERVICE=sendgrid
EMAIL_API_KEY=your-email-api-key
EMAIL_FROM=noreply@example.com

# Push Notifications (FCM)
FCM_SERVER_KEY=your-fcm-server-key

# AWS S3 / MinIO Configuration
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=edu-platform
S3_REGION=us-east-1

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3007
