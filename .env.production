# Production Environment Variables

# Mock Mode (always false in production)
VITE_USE_MOCK=false

# API Configuration
VITE_API_URL=https://api.egitimgalaksisi.com
VITE_WS_URL=wss://api.egitimgalaksisi.com
VITE_CDN_URL=https://cdn.egitimgalaksisi.com

# Gemini API
VITE_GEMINI_API_KEY=

# Feature Flags
VITE_ENABLE_PWA=true
VITE_ENABLE_OFFLINE=true
VITE_ENABLE_ANALYTICS=true

# Debug
VITE_DEBUG=false
